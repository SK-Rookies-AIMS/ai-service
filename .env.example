# Application
APP_NAME=AI Service
APP_VERSION=0.1.0
DEBUG=dev
LOG_LEVEL=INFO

# External APIs
OPENAI_API_KEY=
AI_MANUAL_API_URL=
COLLEAGUE_SKILL_API_URL=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=

# Redis Cache
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=aims:ai-service
REDIS_CACHE_TTL_SECONDS=300

# Main MySQL DB
# Bottleneck analysis results are written to this DB.
MAIN_DATABASE_URL=mysql+pymysql://aims_user:change-me@localhost:3306/maindb?charset=utf8mb4

# Sample MySQL DB
# Use this DB for sample/source data connections when needed.
SAMPLE_DATABASE_URL=mysql+pymysql://sample_user:change-me@localhost:3306/sampledb?charset=utf8mb4
